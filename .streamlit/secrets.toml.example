# Modelo de segredos. NÃO versione o secrets.toml de verdade.
#
# Uso local: renomeie este arquivo para "secrets.toml" (fica na pasta .streamlit/).
# Streamlit Cloud: cole este conteúdo em "Settings → Secrets" do app.

# Senha de acesso ao app (troque por uma forte).
app_password = "troque-esta-senha"

# Banco persistente na nuvem. Sem isto, o app usa SQLite local (não persiste na nuvem).
# Exemplo Neon/Supabase (Postgres):
# DATABASE_URL = "postgresql://usuario:senha@host.neon.tech/dbname?sslmode=require"
